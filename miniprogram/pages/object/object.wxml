<view class="page" wx:if="{{object}}">
  <!-- ===== 状态 1: 修复中 ===== -->
  <block wx:if="{{object.status === 'repairing'}}">
    <view class="repair-head">
      <view class="object-no">{{object.objectNo || 'No.001'}}</view>
      <view class="progress-label">记忆正在修复 {{object.repairProgress || 0}}%</view>
    </view>

    <image
      class="object-image"
      src="{{object.imageProcessed || object.imageOriginal}}"
      mode="aspectFill"
      style="filter: grayscale({{grayscale}}%) blur({{blur}}rpx);"
    />

    <!-- 我来讲讲它 -->
    <view class="repair-module">
      <view class="repair-module-title">我来讲讲它</view>
      <view class="repair-module-desc">每讲一点，这件老东西就会更清楚一点。</view>

      <textarea
        class="repair-textarea"
        placeholder="说说它为什么还在，或者它和谁有关"
        value="{{contentText}}"
        bindinput="onInput"
      />

      <view class="repair-buttons">
        <button class="repair-btn memory-btn" data-type="memory" bindtap="submitByType">讲一段记忆</button>
        <button class="repair-btn answer-btn" data-type="answer" bindtap="submitByType">回答家人的问题</button>
      </view>

      <button
        class="elder-voice-btn"
        loading="{{recording}}"
        bindtouchstart="startRecord"
        bindtouchend="stopRecord"
        bindtouchcancel="stopRecord"
      >
        <view wx:if="{{!recording}}">
          <text class="elder-voice-icon">🎤</text>
          <text>按住说话</text>
        </view>
        <view wx:else>正在听你说...</view>
      </button>
    </view>

    <!-- 接龙记录 -->
    <view class="panel">
      <view class="section-title">家人问我的</view>
      <block wx:if="{{contributions.length}}">
        <view wx:for="{{contributions}}" wx:key="_id" class="contribution">
          <view class="tag {{item.type}}">{{typeText[item.type]}}</view>
          <view class="content" wx:if="{{item.contentText}}">{{item.displayText || item.contentText}}</view>
          <audio wx:if="{{item.audioUrl}}" src="{{item.audioUrl}}" controls></audio>
        </view>
      </block>
      <view wx:else class="empty">家人还没来问，你也可以先讲一段。</view>
    </view>
  </block>

  <!-- ===== 状态 2: 修复满 100%，等待生成 ===== -->
  <block wx:if="{{object.status !== 'repairing' && !card}}">
    <view class="repair-head">
      <view class="object-no">{{object.objectNo || 'No.001'}}</view>
      <view class="progress-label done">记忆修复已完成</view>
    </view>

    <image
      class="object-image clear"
      src="{{object.imageProcessed || object.imageOriginal}}"
      mode="aspectFill"
    />

    <view class="congrats-banner">
      <view class="congrats-text">讲得差不多了，这件老东西被重新看见了</view>
      <view class="congrats-desc">现在可以为它生成一张家庭展品卡</view>
    </view>

    <view class="panel">
      <view class="section-title">家人问我的</view>
      <block wx:if="{{contributions.length}}">
        <view wx:for="{{contributions}}" wx:key="_id" class="contribution">
          <view class="tag {{item.type}}">{{typeText[item.type]}}</view>
          <view class="content" wx:if="{{item.contentText}}">{{item.displayText || item.contentText}}</view>
          <audio wx:if="{{item.audioUrl}}" src="{{item.audioUrl}}" controls></audio>
        </view>
      </block>
    </view>

    <button class="generate-button" loading="{{generating}}" bindtap="generateCard">
      生成我的家庭展品卡
    </button>
  </block>

  <!-- ===== 状态 3: 已生成展品卡 ===== -->
  <block wx:if="{{card}}">
    <image class="hero-image" src="{{object.imageOriginal}}" mode="aspectFill" />

    <view class="card-title">{{card.title}}</view>
    <view class="card-subtitle">{{object.objectNo}} · 家庭展品卡</view>

    <view class="panel">
      <view class="label">关联人物</view>
      <view class="chips">
        <view wx:for="{{card.people}}" wx:key="*this" class="chip">{{item}}</view>
      </view>
    </view>

    <view class="panel">
      <view class="label">关键词</view>
      <view class="chips">
        <view wx:for="{{card.keywords}}" wx:key="*this" class="chip">{{item}}</view>
      </view>
    </view>

    <view class="panel">
      <view class="label">展品说明</view>
      <view class="body">{{card.description}}</view>
    </view>

    <view class="panel">
      <view class="label">记忆谱系</view>
      <view wx:for="{{card.memories}}" wx:key="text" class="memory-item">
        <view class="memory-person">{{item.person}}</view>
        <view class="body">{{item.text}}</view>
      </view>
    </view>

    <view class="panel" wx:if="{{card.familyMessage}}">
      <view class="label">家人留言</view>
      <view class="body">{{card.familyMessage}}</view>
    </view>
  </block>
</view>
