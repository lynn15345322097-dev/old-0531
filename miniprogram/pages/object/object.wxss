/* === 通用 === */
.page {
  padding: 40rpx 36rpx 80rpx;
  min-height: 100vh;
}

.object-no {
  font-size: 28rpx;
  color: #998f7e;
}

.progress-label {
  font-size: 40rpx;
  font-weight: 800;
  color: #aa7d54;
}

.progress-label.done {
  color: #5b6d42;
}

.object-admin-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.object-admin-name {
  font-size: 24rpx;
  color: #7a5a2c;
  font-weight: 700;
}

.admin-badge {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #efe3cc;
  color: #7a5a2c;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.3;
}

/* 线索进度 */
.clue-progress {
  margin-top: 8rpx;
}

.clue-count {
  font-size: 26rpx;
  color: #998f7e;
  font-weight: 500;
}

.new-clues {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.new-clues-label {
  font-size: 24rpx;
  color: #aa7d54;
  font-weight: 700;
}

.new-clue-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #f0e6d3;
  color: #7a5a2c;
  font-size: 24rpx;
  font-weight: 600;
}

/* 已点亮线索面板 */
.clue-tags-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #faf7f0;
  border: 1rpx solid #e5dac8;
}

.clue-tags-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #665f54;
  margin-bottom: 16rpx;
}

.clue-tags-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.clue-tag-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.clue-tag-type {
  font-size: 24rpx;
  color: #998f7e;
  min-width: 96rpx;
  flex-shrink: 0;
  line-height: 1.6;
}

.clue-tag-labels {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.clue-label-chip {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  background: #e8dece;
  color: #5b4636;
  font-size: 24rpx;
}

.image-wrap {
  position: relative;
  margin-top: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.object-image {
  display: block;
  width: 100%;
  height: auto;
  background: #e8dece;
  transition: filter 0.4s ease;
}

/* === 修复互动模块 === */
.repair-module {
  margin-top: 32rpx;
  padding: 36rpx 32rpx;
  border-radius: 20rpx;
  background: #faf7f0;
  border: 1rpx solid #ece3d2;
}

.repair-module-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #23201b;
  margin-bottom: 8rpx;
}

.repair-module-desc {
  font-size: 26rpx;
  color: #998f7e;
  margin-bottom: 24rpx;
}

.repair-textarea {
  width: 100%;
  min-height: 100rpx;
  max-height: 160rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid #e5dac8;
  font-size: 30rpx;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

/* 两个并排按钮 */
.repair-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.repair-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.repair-btn::after {
  border: none;
}

.repair-btn:active {
  transform: scale(0.97);
}

.question-btn {
  background: #365c7d;
  color: #fff;
}

.memory-btn {
  background: #7a5a2c;
  color: #fff;
}

.answer-btn {
  background: #5b6d42;
  color: #fff;
}

/* 语音按钮 - 暖棕描边样式 */
.voice-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  background: #faf7f0;
  border: 2rpx solid #aa7d54;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #aa7d54;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.voice-btn::after {
  border: none;
}

.voice-btn:active {
  background: #f5efe4;
  transform: scale(0.98);
}

.voice-btn.is-recording {
  background: #fdf2f2;
  border-color: #c45a5a;
  color: #c45a5a;
}

.voice-icon {
  font-size: 36rpx;
  line-height: 1;
}

.recording-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.recording-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c45a5a;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(1.3); }
}

/* 自定义音频播放器 */
.audio-player {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #f5f0e6;
}

.audio-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #aa7d54;
  color: #fff;
  font-size: 22rpx;
  flex-shrink: 0;
}

.audio-duration {
  font-size: 24rpx;
  color: #998f7e;
  min-width: 72rpx;
  flex-shrink: 0;
}

.audio-bar-wrap {
  flex: 1;
  height: 6rpx;
  border-radius: 3rpx;
  background: #e0d6c4;
  overflow: hidden;
}

.audio-bar-fill {
  height: 100%;
  border-radius: 3rpx;
  background: #aa7d54;
  transition: width 0.3s ease;
}

.audio-bar-fill.active {
  background: #c45a5a;
  animation: barPulse 0.8s ease-in-out infinite;
}

@keyframes barPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

/* === 记忆档案卡片 === */
.panel {
  margin-top: 32rpx;
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #3d3730;
}

.empty {
  font-size: 28rpx;
  color: #c4b99d;
  padding: 16rpx 0;
}

/* 卡片容器 */
.memory-card {
  display: flex;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  background: #fffaf0;
  border: 1rpx solid #e5dac8;
  overflow: hidden;
}

/* 左侧色条 */
.card-bar {
  width: 8rpx;
  flex-shrink: 0;
}

.card-question .card-bar { background: #4a7a9e; }
.card-memory  .card-bar { background: #b08a5c; }
.card-answer  .card-bar { background: #6b8a4a; }

.memory-card.member-grandma {
  background: #fff8ec;
  border-color: #ead5ad;
}
.memory-card.member-grandma .card-bar { background: #c18a2f; }
.memory-card.member-grandma .card-author { color: #8a5a14; }

.memory-card.member-grandpa {
  background: #f3faf5;
  border-color: #c8dfce;
}
.memory-card.member-grandpa .card-bar { background: #4f8f63; }
.memory-card.member-grandpa .card-author { color: #2e6b43; }

.memory-card.member-dad {
  background: #f2f7fc;
  border-color: #c4d8ea;
}
.memory-card.member-dad .card-bar { background: #437ca8; }
.memory-card.member-dad .card-author { color: #275f8a; }

.memory-card.member-mom {
  background: #fff4f3;
  border-color: #ebc7c2;
}
.memory-card.member-mom .card-bar { background: #c2645d; }
.memory-card.member-mom .card-author { color: #9a433e; }

.memory-card.member-grandson {
  background: #f7f5ff;
  border-color: #d7cdea;
}
.memory-card.member-grandson .card-bar { background: #7463a8; }
.memory-card.member-grandson .card-author { color: #58478d; }

.memory-card.member-family {
  background: #fbf8f1;
}
.memory-card.member-family .card-bar { background: #8a8172; }

/* 卡片内容区 */
.card-body {
  flex: 1;
  padding: 20rpx 24rpx;
  min-width: 0;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-author {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #3d3730;
  min-width: 0;
  flex-wrap: wrap;
}

.member-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #6b8a4a;
}

.card-delta {
  font-size: 24rpx;
  font-weight: 700;
  color: #b08a5c;
  flex-shrink: 0;
}

.card-content {
  font-size: 30rpx;
  line-height: 1.7;
  color: #23201b;
}

.card-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b3a68f;
}

.reply-list {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eadfce;
}

.reply-item {
  padding: 18rpx 0 18rpx 22rpx;
  border-left: 4rpx solid #d8c7ae;
}

.reply-item + .reply-item {
  border-top: 1rpx dashed #eadfce;
}

.reply-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.reply-author {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #5b4636;
}

.reply-item.member-grandma {
  border-left-color: #c18a2f;
  background: rgba(193, 138, 47, 0.05);
}
.reply-item.member-grandma .reply-author { color: #8a5a14; }

.reply-item.member-grandpa {
  border-left-color: #4f8f63;
  background: rgba(79, 143, 99, 0.06);
}
.reply-item.member-grandpa .reply-author { color: #2e6b43; }

.reply-item.member-dad {
  border-left-color: #437ca8;
  background: rgba(67, 124, 168, 0.06);
}
.reply-item.member-dad .reply-author { color: #275f8a; }

.reply-item.member-mom {
  border-left-color: #c2645d;
  background: rgba(194, 100, 93, 0.06);
}
.reply-item.member-mom .reply-author { color: #9a433e; }

.reply-item.member-grandson {
  border-left-color: #7463a8;
  background: rgba(116, 99, 168, 0.06);
}
.reply-item.member-grandson .reply-author { color: #58478d; }

.reply-item.member-family {
  border-left-color: #8a8172;
}

.reply-content {
  font-size: 28rpx;
  line-height: 1.65;
  color: #322c25;
}

/* === 恭喜 Banner === */
.congrats-banner {
  margin-top: 28rpx;
  padding: 36rpx 28rpx;
  border-radius: 16rpx;
  background: #f0f6ea;
  border: 1rpx solid #d0ddc0;
  text-align: center;
}

.congrats-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #3d4f2e;
}

.congrats-desc {
  margin-top: 10rpx;
  color: #6b7a5c;
  font-size: 28rpx;
  line-height: 1.5;
}

/* === 生成按钮 === */
.generate-button {
  width: 100%;
  height: 100rpx;
  margin-top: 32rpx;
  background: linear-gradient(135deg, #23201b 0%, #3d3730 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 4rpx;
}

.generate-button::after {
  border: none;
}

/* === Card === */
.hero-image {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 16rpx;
  background: #e8dece;
}

.card-title {
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #23201b;
  text-align: center;
}

.card-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #998f7e;
  text-align: center;
}

.card-admin-line {
  margin-top: 10rpx;
  text-align: center;
  font-size: 24rpx;
  color: #7a5a2c;
  font-weight: 700;
}

.label {
  margin-bottom: 16rpx;
  color: #665f54;
  font-size: 26rpx;
  font-weight: 700;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 6rpx;
  background: #e8dece;
  font-size: 26rpx;
}

.body {
  font-size: 30rpx;
  line-height: 1.7;
}

.memory-item {
  padding: 18rpx 0;
  border-top: 1rpx solid #e5dac8;
}

.memory-item:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.card-intro {
  margin-top: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #998f7e;
  font-style: italic;
  line-height: 1.5;
}

.chip-tag {
  background: #e8e0cc;
  color: #6b5e3e;
  font-weight: 600;
}

.quote {
  font-size: 32rpx;
  line-height: 1.7;
  color: #5b4636;
  font-style: italic;
  padding: 16rpx 0;
}

.memory-person {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

/* ===== 新增：提示词、引用、贡献度评定 ===== */

.repair-hint {
  margin: 16rpx 0 12rpx;
  padding: 16rpx 20rpx;
  border-left: 4rpx solid #c9b78b;
  background: #fbf7ec;
  font-size: 26rpx;
  color: #7a6a4a;
  line-height: 1.6;
  border-radius: 0 12rpx 12rpx 0;
}

.quote-preview {
  display: flex;
  align-items: flex-start;
  margin: 0 0 12rpx;
  padding: 16rpx 20rpx;
  background: #efe9d8;
  border-left: 4rpx solid #b39a5c;
  border-radius: 0 12rpx 12rpx 0;
}
.quote-preview-body {
  flex: 1;
  font-size: 26rpx;
  color: #6b5b3a;
  line-height: 1.5;
}
.quote-preview-label {
  margin-right: 8rpx;
  padding: 2rpx 10rpx;
  background: #b39a5c;
  color: #fff;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.quote-preview-author {
  font-weight: 700;
  margin-right: 4rpx;
}
.quote-preview-text {
  color: #6b5b3a;
}
.quote-preview-clear {
  margin-left: 12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  color: #9c8a5c;
  font-size: 36rpx;
}

.quote-box {
  display: block;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background: #f3eee0;
  border-left: 4rpx solid #c9b78b;
  border-radius: 0 8rpx 8rpx 0;
  font-size: 24rpx;
  color: #7a6a4a;
  line-height: 1.5;
}
.quote-box-author {
  font-weight: 700;
  margin-right: 4rpx;
}
.quote-box-text {
  color: #7a6a4a;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e0d6bc;
  flex-wrap: wrap;
}
.card-action {
  font-size: 24rpx;
  color: #8a7544;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #f6f0dc;
}
.quote-btn {
  cursor: pointer;
}
.repair-picker {
  background: #ece1bf;
  color: #6b5b2b;
  font-weight: 600;
}

/* ===== 引用补充浮层 ===== */

.quote-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(40, 30, 15, 0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.quote-panel {
  width: 100%;
  background: #fbf6e7;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx 32rpx 40rpx;
  box-shadow: 0 -8rpx 24rpx rgba(80, 60, 20, 0.18);
  animation: quote-slide-up 220ms ease-out;
}

@keyframes quote-slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.quote-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.quote-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5b4a20;
}
.quote-panel-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 40rpx;
  color: #9c8a5c;
}

.quote-panel-quote {
  padding: 16rpx 20rpx;
  background: #efe9d8;
  border-left: 4rpx solid #b39a5c;
  border-radius: 0 12rpx 12rpx 0;
  font-size: 26rpx;
  color: #6b5b3a;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.quote-panel-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #d9cda4;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #3a2d10;
  line-height: 1.6;
  box-sizing: border-box;
}

.quote-panel-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.quote-panel-cancel,
.quote-panel-submit {
  flex: 1;
  padding: 20rpx 0;
  font-size: 30rpx;
  border-radius: 14rpx;
  border: none;
}
.quote-panel-cancel {
  background: #ece1bf;
  color: #6b5b2b;
}
.quote-panel-submit {
  background: #8a7544;
  color: #fff;
  font-weight: 700;
}
.quote-panel-submit::after,
.quote-panel-cancel::after {
  border: none;
}
