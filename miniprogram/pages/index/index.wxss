.home {
  min-height: 100vh;
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
}

/* ---- Hero ---- */
.hero {
  text-align: center;
  padding-top: 80rpx;
  padding-bottom: 60rpx;
}

.slogan {
  font-size: 32rpx;
  color: #998f7e;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.main-title {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.3;
  color: #23201b;
}

.highlight {
  color: #aa7d54;
}

.notice {
  margin: 0 auto 24rpx;
  padding: 12rpx 24rpx;
  display: inline-block;
  font-size: 26rpx;
  line-height: 1.5;
  color: #8a6a47;
  background: #fbf3e6;
  border: 1rpx solid #e8d5b3;
  border-radius: 16rpx;
}

/* ---- Big Button ---- */
.actions {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 60rpx;
}

.button-primary {
  width: 480rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #23201b 0%, #3d3730 100%);
  border-radius: 24rpx;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 32rpx rgba(35, 32, 27, 0.2);
}

.button-primary::after {
  border: none;
}

.button-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.button-icon {
  font-size: 48rpx;
  line-height: 1;
}

.button-label {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

/* ---- Divider ---- */
.divider {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 40rpx;
  margin-bottom: 36rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e5dac8;
}

.divider-text {
  font-size: 26rpx;
  color: #b3a68f;
  white-space: nowrap;
}

/* ---- Panel ---- */
.panel-summary {
  text-align: center;
  font-size: 28rpx;
  color: #998f7e;
  margin-bottom: 30rpx;
}

.recent-list {
  border-top: 1rpx solid #ece3d2;
  border-bottom: 1rpx solid #ece3d2;
}

.object-row {
  display: flex;
  gap: 24rpx;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #ece3d2;
}

.object-row:first-of-type {
  border-top: 0;
}

.thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 10rpx;
  background: #e8dece;
  flex-shrink: 0;
  transition: filter 0.4s ease;
}

/* 缩略图按修复进度分档：参数比详情页温和，确保 96rpx 小图仍能看出形状 */
.thumb.progress-0 {
  filter: grayscale(100%) blur(6rpx) contrast(0.7) brightness(0.85) saturate(0);
}
.thumb.progress-25 {
  filter: grayscale(85%) blur(4rpx) contrast(0.8) brightness(0.9) saturate(0.2);
}
.thumb.progress-50 {
  filter: grayscale(60%) blur(2.5rpx) contrast(0.9) brightness(0.95) saturate(0.5);
}
.thumb.progress-75 {
  filter: grayscale(25%) blur(1rpx) contrast(0.95) brightness(1) saturate(0.8);
}
.thumb.progress-100 {
  filter: none;
}

.row-text {
  flex: 1;
  min-width: 0;
}

.row-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #23201b;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.row-status {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #998f7e;
}

.empty {
  text-align: center;
  font-size: 26rpx;
  color: #c4b99d;
  padding: 24rpx 0;
}
