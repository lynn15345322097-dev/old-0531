<view class="page home">
  <view class="hero">
    <view class="slogan">那些没有被丢掉的东西</view>
    <view class="main-title">拍下家里的东西，<text class="highlight">讲讲它的故事</text></view>
    <view class="hint">每件东西背后，都有家人记得的故事</view>
  </view>

  <view class="actions">
    <button class="button-primary" bindtap="goUpload">
      <view class="button-icon">📷</view>
      <view class="button-label">上传一件家里的东西</view>
    </button>
  </view>

  <view class="divider">
    <view class="divider-line"></view>
    <text class="divider-text">家里的藏品</text>
    <view class="divider-line"></view>
  </view>

  <view class="panel">
    <view wx:if="{{totalCount > 0}}" class="panel-summary">已有 {{totalCount}} 件藏品入馆，{{repairingCount}} 件等待修复</view>
    <view wx:else class="panel-summary">还没有藏品，先上传第一件吧</view>

    <view wx:if="{{recentObjects.length}}" class="recent-list">
      <view
        wx:for="{{recentObjects}}"
        wx:key="_id"
        class="object-row"
        data-id="{{item._id}}"
        bindtap="goObject"
      >
        <image class="thumb progress-{{item.progressBucket}}" src="{{item.imageOriginal}}" mode="aspectFill" />
        <view class="row-text">
          <view class="row-name">{{item.displayTitle || item.title}}</view>
          <view class="row-status">
            <text wx:if="{{item.status === 'repairing'}}">修复中 · {{item.repairProgress || 0}}%</text>
            <text wx:else>已入馆</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty">还没有藏品，点击上方按钮上传第一件吧</view>
  </view>
</view>
