<view class="page home">
  <view class="hero">
    <view class="title">老东西</view>
    <view class="subtitle">把一件旧物，从模糊的照片修复成有名字、有关系、有记忆的家庭展品。</view>
  </view>

  <view class="actions">
    <button class="button" bindtap="goUpload">上传一个物件</button>
  </view>

  <view class="panel">
    <view class="section-title">待修复藏品</view>
    <block wx:if="{{repairingObjects.length}}">
      <view
        wx:for="{{repairingObjects}}"
        wx:key="_id"
        class="object-row"
        data-id="{{item._id}}"
        bindtap="goObject"
      >
        <image class="thumb" src="{{item.imageOriginal}}" mode="aspectFill" />
        <view class="row-main">
          <view class="row-title">{{item.objectNo || 'No.001'}} {{item.title}}</view>
          <view class="row-progress">修复度 {{item.repairProgress || 0}}%</view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">还没有待修复藏品</view>
  </view>

  <view class="panel">
    <view class="section-title">最近入馆藏品</view>
    <block wx:if="{{recentCompleted.length}}">
      <view
        wx:for="{{recentCompleted}}"
        wx:key="_id"
        class="object-row"
        data-id="{{item._id}}"
        bindtap="goObject"
      >
        <image class="thumb" src="{{item.imageOriginal}}" mode="aspectFill" />
        <view class="row-main">
          <view class="row-title">{{item.objectNo || 'No.001'}} {{item.title}}</view>
          <view class="muted" wx:if="{{item.repairProgress >= 100}}">已入馆</view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">还没有入馆藏品</view>
  </view>
</view>
