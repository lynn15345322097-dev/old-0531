<view class="page home">
  <view class="hero">
    <view class="subtitle">那些没有被丢掉的东西</view>
    <view class="title">修复一段记忆，找回一件物品</view>
  </view>

  <view class="actions">
    <button class="button" bindtap="goUpload">上传你的物品</button>
  </view>

  <view class="panel">
    <view class="section-title">待修复藏品</view>
    <block wx:if="{{repairingObjects.length}}">
      <view
        wx:for="{{repairingObjects}}"
        wx:key="_id"
        class="object-row"
        data-id="{{item._id}}"
        bindtap="goObject"
      >
        <image class="thumb" src="{{item.imageOriginal}}" mode="aspectFill" />
        <view class="row-main">
          <view class="row-title">{{item.objectNo || 'No.001'}} {{item.title}}</view>
          <view class="progress-bar-wrap">
            <view class="progress-bar" style="width: {{item.repairProgress || 0}}%"></view>
          </view>
          <view class="row-progress">修复度 {{item.repairProgress || 0}}%</view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">还没有待修复藏品</view>
  </view>

  <view class="panel">
    <view class="section-title">最近入馆藏品</view>
    <block wx:if="{{recentCompleted.length}}">
      <view
        wx:for="{{recentCompleted}}"
        wx:key="_id"
        class="object-row"
        data-id="{{item._id}}"
        bindtap="goObject"
      >
        <image class="thumb" src="{{item.imageOriginal}}" mode="aspectFill" />
        <view class="row-main">
          <view class="row-title">{{item.displayTitle || item.title}}</view>
          <view class="muted">{{item.objectNo}} · 已入馆</view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">还没有入馆藏品</view>
  </view>
</view>
