<view class="page">
  <view class="title">我的</view>

  <block wx:if="{{user && family}}">
    <!-- 家庭信息 -->
    <view class="panel">
      <view class="panel-title">我的家庭</view>
      <view class="row">
        <view class="row-label">家庭名称</view>
        <view class="row-value">{{family.familyName}}</view>
      </view>
    </view>

    <!-- 个人信息 -->
    <view class="panel">
      <view class="panel-title">我的身份</view>
      <view class="row">
        <view class="row-label">称呼</view>
        <view class="row-value">{{user.name || '未设置'}}</view>
      </view>
      <view class="row">
        <view class="row-label">角色</view>
        <view class="row-value">{{user.role === 'elder' ? '老人' : '家人'}}</view>
      </view>
      <view class="row" wx:if="{{user.relation}}">
        <view class="row-label">关系</view>
        <view class="row-value">{{user.relation}}</view>
      </view>
    </view>

    <!-- 邀请码 -->
    <view class="panel">
      <view class="panel-title">家庭邀请码</view>
      <view class="invite-row">
        <view class="invite-code">{{inviteCode}}</view>
        <button class="copy-btn" bindtap="copyInviteCode">复制</button>
      </view>
      <view class="muted" style="margin-top: 12rpx; font-size: 24rpx;">家人输入此邀请码即可加入家庭</view>
    </view>
  </block>

  <!-- 未绑定家庭 -->
  <view wx:else class="empty">
    <view class="muted" style="margin-bottom: 28rpx;">暂未绑定家庭</view>
  </view>
</view>
