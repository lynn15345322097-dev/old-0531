<view class="page">
  <view class="title">我的家庭</view>

  <block wx:if="{{user && family}}">
    <!-- 家庭信息 -->
    <view class="panel identity-panel">
      <view class="panel-title">我的家庭</view>
      <view class="identity-family-name">{{family.familyName}}</view>
    </view>

    <!-- 个人信息 -->
    <view class="panel identity-panel">
      <view class="panel-title">我的身份</view>
      <view class="identity-rows">
        <view class="row">
          <view class="row-label">当前使用人</view>
          <view class="row-value">{{user.displayName || '未设置'}}</view>
        </view>
        <view class="row">
          <view class="row-label">家庭身份</view>
          <view class="row-value">{{user.relation || '未设置'}}</view>
        </view>
      </view>
    </view>

    <!-- 本地预览身份切换 -->
    <view wx:if="{{demoMode}}" class="panel demo-switch-panel">
      <view class="panel-title">本地预览当前使用人</view>
      <view class="switch-desc">切换后，上传新藏品和新增记忆都会记录为对应家庭成员。</view>
      <view class="member-grid">
        <button
          wx:for="{{demoMembers}}"
          wx:key="openid"
          class="member-btn {{user.openid === item.openid ? 'active' : ''}}"
          data-openid="{{item.openid}}"
          bindtap="switchDemoUser"
        >
          <view class="member-name">{{item.displayName}}</view>
          <view class="member-relation">{{item.openid === user.openid ? '当前使用人' : '点击切换'}}</view>
        </button>
      </view>
    </view>

    <!-- 邀请码 -->
    <view class="panel invite-panel">
      <view class="panel-title">邀请家人一起修复</view>
      <view class="invite-desc">把邀请码发给家人，让他们一起来补全这些藏品的记忆。</view>
      <view class="invite-row">
        <view class="invite-code">{{inviteCode}}</view>
        <button class="copy-btn" bindtap="copyInviteCode">复制</button>
      </view>
    </view>

    <view wx:if="{{demoMode}}" class="reset-area">
      <view class="reset-title">画面不一致时</view>
      <view class="reset-desc">恢复到仓库内置的同一份初始演示数据，方便和其他电脑对齐预览。</view>
      <button class="reset-btn" bindtap="resetDemoData">恢复到统一初始展品</button>
    </view>
  </block>

  <!-- 未绑定家庭 -->
  <view wx:else class="empty">
    <view class="muted" style="margin-bottom: 28rpx;">暂未绑定家庭</view>
  </view>
</view>
