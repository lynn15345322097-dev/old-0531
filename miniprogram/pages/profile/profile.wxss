.page {
  padding: 40rpx 36rpx 80rpx;
  min-height: 100vh;
}

/* === Identity panels === */
.identity-panel {
  text-align: center;
}

.identity-family-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #23201b;
  margin-top: 12rpx;
  letter-spacing: 4rpx;
}

.identity-rows {
  margin-top: 8rpx;
}

.panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #998f7e;
  margin-bottom: 8rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #ece3d2;
}

.row:first-of-type {
  border-top: 0;
}

.row-label {
  color: #665f54;
  font-size: 30rpx;
}

.row-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #23201b;
}

.member-badge {
  color: #aa7d54;
  font-size: 32rpx;
}

/* === Local preview switch === */
.demo-switch-panel {
  text-align: left;
}

.switch-desc {
  margin-bottom: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #998f7e;
}

.member-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.member-btn {
  min-width: 0;
  height: 112rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ded2bf;
  background: #fff;
  color: #23201b;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  text-align: left;
  line-height: 1.3;
}

.member-btn::after {
  border: none;
}

.member-btn.active {
  background: #23201b;
  border-color: #23201b;
  color: #fff;
}

.member-name {
  font-size: 30rpx;
  font-weight: 800;
}

.member-relation {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #998f7e;
}

.member-btn.active .member-relation {
  color: #d9c8a8;
}

/* === Invite === */
.invite-panel {
  text-align: center;
}

.invite-desc {
  font-size: 26rpx;
  color: #998f7e;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.invite-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.invite-code {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 1rpx solid #ded2bf;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
  color: #23201b;
}

.copy-btn {
  min-width: 140rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 10rpx;
  background: #23201b;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
}

.reset-btn {
  margin-top: 24rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #ece3d2;
  color: #998f7e;
  font-size: 26rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reset-btn::after {
  border: none;
}
