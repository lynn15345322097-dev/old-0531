.onboarding {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 120rpx;
}

.hero {
  margin-bottom: 48rpx;
}

.actions {
  display: grid;
  gap: 20rpx;
}

.form {
  flex: 1;
}

.section-title {
  margin-bottom: 32rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.label {
  margin-top: 28rpx;
  margin-bottom: 14rpx;
  color: #665f54;
  font-size: 26rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #fffaf0;
  border: 1rpx solid #ded2bf;
  font-size: 30rpx;
}

.input.code {
  font-size: 44rpx;
  letter-spacing: 12rpx;
  text-align: center;
}

.chip-row {
  display: flex;
  gap: 16rpx;
}

.chip {
  min-width: 160rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  background: #e8dece;
  text-align: center;
  color: #665f54;
  font-size: 28rpx;
}

.chip.active {
  background: #23201b;
  color: #fff;
}

.picker {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #fffaf0;
  border: 1rpx solid #ded2bf;
  font-size: 30rpx;
  color: #23201b;
}

.form .button {
  margin-top: 44rpx;
}

.form .button.secondary {
  margin-top: 16rpx;
}
