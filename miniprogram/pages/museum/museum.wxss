.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin: 32rpx 0 20rpx;
  padding: 8rpx;
  border-radius: 8rpx;
  background: #e8dece;
}

.tab {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 6rpx;
  text-align: center;
  color: #665f54;
  font-size: 28rpx;
}

.tab.active {
  background: #fffaf0;
  color: #23201b;
  font-weight: 700;
}

.object-card {
  display: flex;
  gap: 22rpx;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fffaf0;
  border: 1rpx solid #ded2bf;
}

.cover-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  background: #e8dece;
  overflow: hidden;
  flex: 0 0 150rpx;
}

.cover {
  display: block;
  width: 100%;
  height: 100%;
  transition: filter 0.3s ease;
}

.cover-wrap.unrepaired::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(35, 32, 27, 0.18);
  pointer-events: none;
}

.cover-mask {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  z-index: 1;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  background: rgba(35, 32, 27, 0.78);
}

.cover-mask-text {
  color: #fffaf0;
  font-size: 20rpx;
  font-weight: 700;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  margin-bottom: 6rpx;
  font-size: 32rpx;
  font-weight: 700;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.card-meta {
  font-size: 22rpx;
  color: #998f7e;
  margin-bottom: 4rpx;
}

.meta-sep {
  margin: 0 6rpx;
}

.keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
}

.kw-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #f0ebe0;
  color: #665f54;
  font-size: 22rpx;
}

.progress-bar-wrap {
  margin-top: 10rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e8dece;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 4rpx;
  background: #aa7d54;
  transition: width 0.3s ease-out;
}
