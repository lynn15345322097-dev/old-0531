<view class="page">
  <view class="title">上传一个物件</view>
  <view class="subtitle">拍照或选择一张旧物照片，先创建一个“未知藏品”。</view>

  <view class="photo-box" bindtap="chooseImage">
    <image wx:if="{{tempImage}}" class="preview" src="{{tempImage}}" mode="aspectFill" />
    <view wx:else class="photo-placeholder">拍照 / 选择图片</view>
  </view>

  <button class="button" loading="{{uploading}}" disabled="{{!tempImage || uploading}}" bindtap="submit">
    创建未知藏品
  </button>
</view>
