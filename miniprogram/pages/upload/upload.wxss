.photo-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 620rpx;
  margin: 36rpx 0 28rpx;
  border-radius: 8rpx;
  background: #fffaf0;
  border: 2rpx dashed #cfc2ad;
  overflow: hidden;
}

.photo-placeholder {
  color: #756d61;
  font-size: 30rpx;
}

.preview {
  width: 100%;
  height: 100%;
}
